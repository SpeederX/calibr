{
  "name": "calibr",
  "version": "0.1.5",
  "description": "Find the fastest safe llama.cpp model and launch configuration for your hardware.",
  "type": "module",
  "license": "MIT",
  "author": "SpeederX",
  "homepage": "https://github.com/SpeederX/calibr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpeederX/calibr.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/SpeederX/calibr/issues"
  },
  "keywords": [
    "llama.cpp",
    "benchmark",
    "recommendation",
    "local-llm",
    "gguf",
    "cli",
    "ink",
    "wddm",
    "vram",
    "llm"
  ],
  "bin": {
    "calibr": "dist/index.js"
  },
  "files": [
    "dist",
    "engine",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "win32",
    "linux"
  ],
  "scripts": {
    "build": "tsc",
    "bundle-engine": "node scripts/bundle-engine.js",
    "prepack": "node scripts/bundle-engine.js && tsc",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "test:components": "tsc && node --test \"tests/*.test.mjs\"",
    "test": "npm run build && node scripts/all-options-keypress-smoke.mjs && node scripts/smoke-install.js && node --test \"tests/*.test.mjs\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
